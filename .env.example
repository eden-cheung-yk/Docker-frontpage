# DockerDash Environment Variables
# Copy this file to .env and adjust values as needed

# Port the server listens on (inside the container)
PORT=3000

# Directory for SQLite database and uploaded files
DATA_DIR=/app/data

# Initial dashboard title (changeable in Settings UI)
DASHBOARD_TITLE=My Dashboard

# Base URL for auto-detected container links
# Set this to your Docker host's IP or hostname
# Example: http://192.168.1.100 or http://nas.local
HOST_URL=

# Version metadata (set automatically during docker build)
# DOCKERDASH_VERSION=1.0.0
# DOCKERDASH_BUILD_DATE=2026-05-25T12:00:00Z
